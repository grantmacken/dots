#!/usr/bin/env bash
# echo  " ---------------------------------------"
# echo " Setup the Ptyxis default profile       "
# echo " ---------------------------------------"
# echo " With the Ptyxis default profile uuid: $PROFILE_UUID"
# echo " - 1: set the label:  ${PROFILE_LABEL} "
# dconf write /org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/label "'${PROFILE_LABEL}'"
# echo " - 2: set the palette:  ${PROFILE_PALETTE} "
# dconf write /org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/palette "'$PROFILE_PALETTE'"
# echo " - 3: set the default container :  ${PROFILE_DEFAULT_CONTAINER}"
# dconf write /org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/default-container "'${PROFILE_DEFAULT_CONTAINER}'"
#
# NOTE: Ptyxis Tab Keyboard Shortcuts
# Action	Shortcut	     Note
# Next Tab	Ctrl+PageDown	  Cycles forward through the tabs.
# Previous Tab	Ctrl+PageUp	  Cycles backward through the tabs.
# Direct Tab Access	Alt+1  through Alt+9
# Directly jumps to the corresponding tab number (e.g., Alt+3 goes to the third tab).
#
# echo "==========================================================="
# echo " - view Ptyxis default profile"
# echo "==========================================================="
CONTAINER=tbx-coding
TOOLBOX_DEFAULT_CONTAINER=$(podman inspect ${CONTAINER} | jq -r '.[0].Id')
PROFILE_UUID=$(gsettings get org.gnome.Ptyxis default-profile-uuid | tr -d "'")
PROFILE_DEFAULT_CONTAINER=$(gsettings get org.gnome.Ptyxis.Profile:/org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/ default-container | tr -d "'")
printf "PROFILE_UUID: %s\n" $PROFILE_UUID
printf "PROFILE DEFAULT CONTAINER: %s\n" $PROFILE_DEFAULT_CONTAINER
printf "TOOLBOX DEFAULT CONTAINER: %s\n" $TOOLBOX_DEFAULT_CONTAINER
# dconf dump /org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/
# dconf dump /org/gnome/Ptyxis/
#
PROFILE_PALETTE=Kanagawa

echo " ---------------------------------------"
echo " Setup the Ptyxis default profile       "
echo " ---------------------------------------"
echo " With the Ptyxis default profile uuid: $PROFILE_UUID"
echo " - 1: set the label: ${CONTAINER}"
dconf write "/org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/label" "'${CONTAINER}'"
echo " - 2: set the palette:  ${PROFILE_PALETTE} "
dconf write "/org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/palette" "'$PROFILE_PALETTE'"
echo " - 3: set the default container :  ${TOOLBOX_DEFAULT_CONTAINER}"
dconf write "/org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/default-container" "'${TOOLBOX_DEFAULT_CONTAINER}'"

echo " ---------------------------------------"
echo " Setup the key bind for ptyxis          "
echo " ---------------------------------------"
WORKING_DIR=${HOME}/Projects

custom_keybindings=/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings
custom0=/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/
custom1=/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom1/

# Discover project directories (sorted)
mapfile -t PROJECT_DIRS < <(find "${WORKING_DIR}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' | sort)

# Build the full list of custom binding paths: custom0+custom1 fixed, then 2 per project dir
all_customs=("${custom0}" "${custom1}")
for i in "${!PROJECT_DIRS[@]}"; do
  all_customs+=(
    "/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom$((i * 2 + 2))/"
    "/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom$((i * 2 + 3))/"
  )
done
printf -v list_str "'%s'," "${all_customs[@]}"
dconf write "${custom_keybindings}" "[${list_str%,}]"

## TOOLBOX TERMINAL — fixed custom0
dconf write "${custom0}name" "'Toolbox'"
dconf write "${custom0}binding" "'<Control><Alt>t'"
dconf write "${custom0}command" "'ptyxis --working-directory=${WORKING_DIR} --title=toolbox --tab-with-profile=${PROFILE_UUID}'"

## HOST SPAWN — fixed custom1
dconf write "${custom1}name" "'host_spawn'"
dconf write "${custom1}binding" "'<Shift><Alt>t'"
dconf write "${custom1}command" "'ptyxis --working-directory=${WORKING_DIR} --title=host --tab-with-profile=${PROFILE_UUID} -- host-spawn'"

## Per-project: <Control><Alt>{N} → neovim, <Shift><Alt>{N} → copilot
for i in "${!PROJECT_DIRS[@]}"; do
  dir="${PROJECT_DIRS[$i]}"
  dir_lower="${dir,,}"
  num=$((i + 1))
  nvim_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom$((i * 2 + 2))/"
  copilot_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom$((i * 2 + 3))/"
  project_dir="${WORKING_DIR}/${dir}"

  dconf write "${nvim_path}name" "'neovim_${dir_lower}'"
  dconf write "${nvim_path}binding" "'<Control><Alt>${num}'"
  dconf write "${nvim_path}command" "'ptyxis --working-directory=${project_dir} --title=nvim_${dir_lower} --tab-with-profile=${PROFILE_UUID} -- nvim'"

  dconf write "${copilot_path}name" "'copilot_${dir_lower}'"
  dconf write "${copilot_path}binding" "'<Shift><Alt>${num}'"
  dconf write "${copilot_path}command" "'ptyxis --working-directory=${project_dir} --title=copilot_${dir_lower} --tab-with-profile=${PROFILE_UUID} -- copilot --banner --allow-all-tools'"
done

echo "==========================================================="
echo " - view Ptyxis default profile changes made via dconf dump "
echo "==========================================================="
dconf dump /org/gnome/Ptyxis/Profiles/${PROFILE_UUID}/
echo
echo "==========================================================="
echo " - view custom keybinding configuration "
echo "==========================================================="
for path in "${all_customs[@]}"; do
  echo "==========================================================="
  dconf dump "${path}"
done
echo
