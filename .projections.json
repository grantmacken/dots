{
  "*": {
    "project": "dots",
    "log": ".project.log"
  },
    "Makefile": {
    "type": "makefile"
  },
  ".gitignore": {
    "type": "dots"
  },
  ".projections.json": {
    "type": "projections"
  },
  "README.md": {
    "type": "note"
  },
  "notes/*.md": {
    "type": "note"
  },
  "nvim/*.vim": {
    "type": "nvim",
    "activate": [],
    "deactivate": []

  },
    "nvim/site/lua/my/*.lua": {
    "type": "mylua"
  }
}
