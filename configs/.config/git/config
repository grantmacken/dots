[user]
	name = grantmacken
	email = grantmacken@gmail.com
[push]
	default = current
	followTags = true
[core]
	pager = nvimpager
  [diff]
    tool = nvr
[difftool "nvr"]
    cmd = nvr -s -d $LOCAL $REMOTE
[merge]
    tool = nvr
[mergetool "nvr"]
    cmd = nvr -s -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd J | wincmd ='
[tag]
	sort = version:refname
[color]
	pager = no
[pull]
	rebase = false
